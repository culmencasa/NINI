<Page
    x:Class="NINI.Views.Settings.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="关于"
    d:DesignHeight="600"
    d:DesignWidth="800">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="关于" FontSize="28" FontWeight="SemiBold"/>
            <TextBlock Text="应用程序信息" 
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 内容 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 应用信息卡片 -->
                <ui:Card Margin="0,0,0,16">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 应用图标 -->
                        <Border Grid.Column="0" 
                                Width="80" 
                                Height="80" 
                                CornerRadius="12"
                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                Margin="0,0,20,0">
                            <ui:SymbolIcon Symbol="FlashOn24" 
                                          FontSize="40"
                                          Foreground="White"/>
                        </Border>

                        <!-- 应用名称和版本 -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="NINI" 
                                       FontSize="24" 
                                       FontWeight="Bold"/>
                            <TextBlock Text="版本 1.0.0" 
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="14"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="一个轻量级的 Windows 快捷键管理工具" 
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       FontSize="12"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </ui:Card>

                <!-- 功能特性 -->
                <ui:CardExpander Header="功能特性" 
                                 Icon="{ui:SymbolIcon Star24}"
                                 IsExpanded="True"
                                 Margin="0,0,0,8">
                    <StackPanel Margin="16">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="Keyboard24" 
                                          Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                          Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1" 
                                       Text="全局快捷键 - 支持自定义全局快捷键，一键触发各种操作"
                                       TextWrapping="Wrap"/>
                        </Grid>
                        
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="ShieldCheckmark24" 
                                          Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                          Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1" 
                                       Text="冲突检测 - 自动检测快捷键与其他程序的冲突"
                                       TextWrapping="Wrap"/>
                        </Grid>
                        
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="Desktop24" 
                                          Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                          Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1" 
                                       Text="快捷操作 - 一键打开终端、显示IP地址、关闭显示器等"
                                       TextWrapping="Wrap"/>
                        </Grid>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="ArrowMinimize24" 
                                          Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                          Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1" 
                                       Text="系统托盘 - 最小化到托盘运行，不占用任务栏空间"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>

                <!-- 技术信息 -->
                <ui:CardExpander Header="技术信息" 
                                 Icon="{ui:SymbolIcon Info24}"
                                 Margin="0,0,0,8">
                    <StackPanel Margin="16">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="框架" 
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text=".NET 10.0 / WPF"/>
                        </Grid>
                        
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="UI 库" 
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="WPF-UI 3.0"/>
                        </Grid>
                        
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="架构" 
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="MVVM"/>
                        </Grid>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="许可证" 
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="MIT License"/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>

                <!-- 链接 -->
                <ui:CardExpander Header="相关链接" 
                                 Icon="{ui:SymbolIcon Link24}"
                                 Margin="0,0,0,8">
                    <StackPanel Margin="16">
                        <ui:Button Content="GitHub 仓库" 
                                   Icon="{ui:SymbolIcon Link24}"
                                   Appearance="Secondary"
                                   HorizontalAlignment="Left"
                                   Margin="0,0,0,8"
                                   Click="GitHub_Click"/>
                        <ui:Button Content="报告问题" 
                                   Icon="{ui:SymbolIcon Bug24}"
                                   Appearance="Secondary"
                                   HorizontalAlignment="Left"
                                   Click="Issues_Click"/>
                    </StackPanel>
                </ui:CardExpander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
