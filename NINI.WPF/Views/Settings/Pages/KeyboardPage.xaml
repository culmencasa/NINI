<Page
    x:Class="NINI.Views.Settings.Pages.KeyboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="键盘"
    d:DesignHeight="600"
    d:DesignWidth="800">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="快捷键设置" FontSize="28" FontWeight="SemiBold"/>
            <TextBlock Text="配置全局快捷键来快速执行各种操作" 
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 冲突提示 -->
        <Border Grid.Row="0" 
                Background="#33FF6A6A" 
                CornerRadius="8" 
                Padding="16" 
                Margin="0,80,0,16"
                Visibility="{Binding ConflictedCount, Converter={StaticResource GreaterThanZeroToVisibility}}"
                VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Warning24" FontSize="20" Margin="0,0,12,0"/>
                <TextBlock Foreground="#FF6A6A" FontSize="14" VerticalAlignment="Center">
                    <Run Text="有 "/>
                    <Run Text="{Binding ConflictedCount, Mode=OneWay}" FontWeight="Bold"/>
                    <Run Text=" 个快捷键与其他程序冲突，可能无法正常工作"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- 热键列表 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding HotkeyItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                CornerRadius="8"
                                Padding="16"
                                Margin="0,0,0,8"
                                Cursor="Hand"
                                MouseLeftButtonDown="HotkeyItem_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}" 
                                               FontSize="14" 
                                               FontWeight="Medium"/>
                                    <TextBlock Text="{Binding Description}" 
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               FontSize="12"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- 状态 -->
                                <StackPanel Grid.Column="1" 
                                            Orientation="Horizontal"
                                            Margin="16,0">
                                    <ui:SymbolIcon FontSize="16" Margin="0,0,6,0">
                                        <ui:SymbolIcon.Style>
                                            <Style TargetType="ui:SymbolIcon">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConflicted}" Value="True">
                                                        <Setter Property="Symbol" Value="Warning24"/>
                                                        <Setter Property="Foreground" Value="#FF6A6A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsConflicted}" Value="False">
                                                        <Setter Property="Symbol" Value="Checkmark24"/>
                                                        <Setter Property="Foreground" Value="#6CCB5F"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:SymbolIcon.Style>
                                    </ui:SymbolIcon>
                                    <TextBlock Text="{Binding StatusText}" 
                                               FontSize="12"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConflicted}" Value="True">
                                                        <Setter Property="Foreground" Value="#FF6A6A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsConflicted}" Value="False">
                                                        <Setter Property="Foreground" Value="#99AAAAAA"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <!-- 热键显示 -->
                                <Border Grid.Column="2" 
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}" 
                                        CornerRadius="4" 
                                        Padding="12,6">
                                    <TextBlock Text="{Binding HotkeyText}" 
                                               FontFamily="Segoe UI"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <ui:Button Content="重置全部" 
                       Appearance="Secondary"
                       Icon="{ui:SymbolIcon ArrowReset24}"
                       Margin="0,0,12,0"
                       Command="{Binding ResetAllCommand}"/>
            <ui:Button Content="刷新" 
                       Appearance="Secondary"
                       Icon="{ui:SymbolIcon ArrowSync24}"
                       Margin="0,0,12,0"
                       Command="{Binding RefreshCommand}"/>
        </StackPanel>
    </Grid>
</Page>
