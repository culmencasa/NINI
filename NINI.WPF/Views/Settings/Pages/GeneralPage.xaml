<Page
    x:Class="NINI.Views.Settings.Pages.GeneralPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="常规"
    d:DesignHeight="600"
    d:DesignWidth="800">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="常规设置" FontSize="28" FontWeight="SemiBold"/>
            <TextBlock Text="配置应用程序的基本行为" 
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 设置项 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 启动设置 -->
                <ui:CardExpander Header="启动" 
                                 Icon="{ui:SymbolIcon Rocket24}"
                                 Margin="0,0,0,8">
                    <StackPanel Margin="16">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="开机自启动" FontWeight="Medium"/>
                                <TextBlock Text="登录 Windows 时自动启动程序" 
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" 
                                             IsChecked="{Binding AutoStart, Mode=TwoWay}"
                                             VerticalAlignment="Center"/>
                        </Grid>
                        
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="启动时最小化" FontWeight="Medium"/>
                                <TextBlock Text="程序启动后最小化到系统托盘" 
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" 
                                             IsChecked="{Binding StartMinimized, Mode=TwoWay}"
                                             VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>

                <!-- 窗口设置 -->
                <ui:CardExpander Header="窗口" 
                                 Icon="{ui:SymbolIcon Window24}"
                                 Margin="0,0,0,8">
                    <StackPanel Margin="16">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="记住窗口位置" FontWeight="Medium"/>
                                <TextBlock Text="下次启动时恢复上次窗口位置" 
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" 
                                             IsChecked="{Binding RememberWindowPosition, Mode=TwoWay}"
                                             VerticalAlignment="Center"/>
                        </Grid>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="最小化到托盘" FontWeight="Medium"/>
                                <TextBlock Text="关闭窗口时最小化到系统托盘而非退出" 
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" 
                                             IsChecked="{Binding MinimizeToTray, Mode=TwoWay}"
                                             VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>

                <!-- 通知设置 -->
                <ui:CardExpander Header="通知" 
                                 Icon="{ui:SymbolIcon Alert24}"
                                 Margin="0,0,0,8">
                    <StackPanel Margin="16">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="显示操作通知" FontWeight="Medium"/>
                                <TextBlock Text="执行快捷键操作时显示通知提示" 
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" 
                                             IsChecked="{Binding ShowNotifications, Mode=TwoWay}"
                                             VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>

                <!-- 快捷键冲突检测 -->
                <ui:CardExpander Header="快捷键" 
                                 Icon="{ui:SymbolIcon Keyboard24}"
                                 Margin="0,0,0,8">
                    <StackPanel Margin="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="启用冲突检测" FontWeight="Medium"/>
                                <TextBlock Text="检测与其他程序的快捷键冲突" 
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12"/>
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="1" 
                                             IsChecked="{Binding EnableConflictDetection, Mode=TwoWay}"
                                             VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
