<ui:FluentWindow
    x:Class="NINI.Views.Settings.SettingsWindow2"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:pages="clr-namespace:NINI.Views.Settings.Pages"
    Title="选项"
    Width="900"
    Height="650"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    ShowInTaskbar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <ui:TitleBar Grid.Row="0" 
                     Title="选项"
                     ShowMaximize="False"
                     CanMaximize="False"/>

        <!-- 导航视图 -->
        <ui:NavigationView x:Name="NavigationView"
                           Grid.Row="1"
                           PaneDisplayMode="Left"
                           IsBackButtonVisible="Collapsed"
                           IsPaneToggleVisible="True"
                           OpenPaneLength="220">

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="常规" 
                                       Icon="{ui:SymbolIcon Settings24}"
                                       TargetPageType="{x:Type pages:GeneralPage}"/>
                <ui:NavigationViewItem Content="快捷键" 
                                       Icon="{ui:SymbolIcon Keyboard24}"
                                       TargetPageType="{x:Type pages:KeyboardPage}"/>
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="关于" 
                                       Icon="{ui:SymbolIcon Info24}"
                                       TargetPageType="{x:Type pages:AboutPage}"/>
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>
    </Grid>
</ui:FluentWindow>
