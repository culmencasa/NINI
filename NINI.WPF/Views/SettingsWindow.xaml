<Window
    x:Class="NINI.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="设置"
    Width="500"
    Height="450"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Background="#F21A1A1A"
>
    <Window.Resources>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="ItemPanel" TargetType="Border">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ItemText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DescText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#99AAAAAA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style x:Key="HotkeyText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4DA6FF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <Style x:Key="StatusText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Style="{StaticResource HeaderText}">
            <Run Text="快捷键设置"/>
        </TextBlock>

        <!-- 冲突提示 -->
        <Border Grid.Row="1" 
                Background="#33FF6A6A" 
                CornerRadius="6" 
                Padding="12" 
                Margin="0,0,0,16"
                Visibility="{Binding ConflictedCount, Converter={StaticResource GreaterThanZeroToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Foreground="#FF6A6A" FontSize="13" VerticalAlignment="Center">
                    <Run Text="有 "/>
                    <Run Text="{Binding ConflictedCount, Mode=OneWay}" FontWeight="Bold"/>
                    <Run Text=" 个快捷键与其他程序冲突"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- 热键列表 -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding HotkeyItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ItemPanel}"
                                MouseLeftButtonDown="HotkeyItem_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource ItemText}"/>
                                    <TextBlock Text="{Binding Description}" Style="{StaticResource DescText}"/>
                                </StackPanel>

                                <!-- 状态 -->
                                <TextBlock Grid.Column="1" 
                                           Text="{Binding StatusText}" >
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource StatusText}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConflicted}" Value="True">
                                                    <Setter Property="Foreground" Value="#FF6A6A"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsConflicted}" Value="False">
                                                    <Setter Property="Foreground" Value="#99AAAAAA"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- 热键显示 -->
                                <Border Grid.Column="2" 
                                        Background="#3A3A3A" 
                                        CornerRadius="4" 
                                        Padding="12,6">
                                    <TextBlock Text="{Binding HotkeyText}" Style="{StaticResource HotkeyText}"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="重置全部" 
                    Padding="16,8" 
                    Margin="0,0,12,0"
                    Click="ResetAll_Click"/>
            <Button Content="关闭" 
                    Padding="16,8"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
