<Window
  x:Class="NINI.Views.PromptWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="NINI Prompt"
    SizeToContent="WidthAndHeight"
  MinWidth="160"
  MaxWidth="450"
  WindowStyle="None"
  AllowsTransparency="True" 
  Background="Transparent"
  Topmost="True"
  ShowInTaskbar="False"
  WindowStartupLocation="Manual"
  KeyDown="Window_KeyDown"
>
  <Grid x:Name="RootGrid" Margin="15">
    <Border x:Name="BackBorder" Background="Transparent" CornerRadius="16">
      <Border.Effect>
        <DropShadowEffect x:Name="WindowShadow" BlurRadius="15" ShadowDepth="0" Opacity="0.4" />
      </Border.Effect>
    </Border>

    <Grid>
      <Grid.OpacityMask>
        <VisualBrush>
          <VisualBrush.Visual>
            <Border
              Background="White"
              CornerRadius="16"
              Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"
              Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}"
            />
          </VisualBrush.Visual>
        </VisualBrush>
      </Grid.OpacityMask>

      <ProgressBar
        x:Name="CountdownBar"
        Height="3"
        VerticalAlignment="Bottom"
        Minimum="0"
        Maximum="100"
        Value="0"
        BorderThickness="0"
      />

      <StackPanel x:Name="ContentPanel" Margin="32,16,32,18">
        <TextBlock
          x:Name="TxtMain"
          FontSize="18"
          FontWeight="Medium"
          HorizontalAlignment="Center"
        />
        <TextBlock x:Name="TxtSub" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,4" />
        <TextBlock
          x:Name="TxtHotkey"
          FontSize="9"
          FontWeight="SemiBold"
          HorizontalAlignment="Center"
          Margin="0,6,0,0"
        />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
