<Window
  x:Class="NINI.Views.PromptWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="NINI Prompt"
  SizeToContent="Manual"
  Width="800"
  Height="300"
  WindowStyle="None"
  AllowsTransparency="True"
  Background="Transparent"
  Topmost="True"
  ShowInTaskbar="False"
  WindowStartupLocation="Manual"
>
  <Grid x:Name="RootGrid">
    <Grid
      x:Name="IslandContainer"
      Width="200"
      Height="80"
      HorizontalAlignment="Center"
      VerticalAlignment="Bottom"
      Margin="0,0,0,20"
    >
      <Border x:Name="BackBorder" CornerRadius="16" Background="#F21A1A1A">
        <Border.Effect>
          <DropShadowEffect x:Name="WindowShadow" BlurRadius="15" ShadowDepth="0" Opacity="0.4" />
        </Border.Effect>
      </Border>

      <Grid x:Name="ContainerGrid">
        <Grid.OpacityMask>
          <VisualBrush>
            <VisualBrush.Visual>
              <Border
                Background="White"
                CornerRadius="16"
                Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"
                Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}"
              />
            </VisualBrush.Visual>
          </VisualBrush>
        </Grid.OpacityMask>

        <ProgressBar
          x:Name="CountdownBar"
          Height="3"
          VerticalAlignment="Bottom"
          Minimum="0"
          Maximum="100"
          Value="0"
          BorderThickness="0"
        />
                <Grid x:Name="MainContentGrid" Margin="10">
          <StackPanel
            x:Name="ContentPanel"
            Orientation="Vertical"
            Opacity="1"
            Margin="32,16,32,18"
            VerticalAlignment="Center"
          >
            <TextBlock
              x:Name="TxtMain"
              FontSize="18"
              FontWeight="Medium"
              HorizontalAlignment="Center"
            />
            <TextBlock
              x:Name="TxtSub"
              FontSize="12"
              HorizontalAlignment="Center"
              Margin="0,4,0,4"
            />
            <TextBlock
              x:Name="TxtHotkey"
              FontSize="9"
              FontWeight="SemiBold"
              HorizontalAlignment="Center"
              Margin="0,6,0,0"
            />
          </StackPanel>

          <StackPanel
            x:Name="HorizontalPanel"
            Visibility="Collapsed"
            Orientation="Horizontal"
            Opacity="1"
            VerticalAlignment="Center"
          >
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!--<TextBlock
                  Text="🌐"
                  Foreground="Blue"
                  VerticalAlignment="Center"
                  Margin="0,0,6,0"
                />-->
                <TextBlock
                  x:Name="TxtLocalIp"
                  Text="192.168.1.144"
                  FontSize="14"
                  Foreground="DarkBlue"
                  VerticalAlignment="Center"
                />
              </StackPanel>

              <Rectangle
                Width="1"
                Height="16"
                Fill="#40000000"
                Margin="16,0,16,0"
                VerticalAlignment="Center"
              />

              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!--<TextBlock
                  Text="🛜"
                  Foreground="#4DA6FF"
                  VerticalAlignment="Center"
                  Margin="0,0,6,0"
                />-->
                <TextBlock
                  x:Name="TxtGateway"
                  Text="192.168.1.1"
                  FontSize="14"
                  Foreground="#4DA6FF"
                  VerticalAlignment="Center"
                />
              </StackPanel>

              <!--<Rectangle
                Width="1"
                Height="16"
                Fill="#40000000"
                Margin="16,0,16,0"
                VerticalAlignment="Center"
              />-->

              <!--<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock
                  Text="⌨"
                  Foreground="#B266FF"
                  VerticalAlignment="Center"
                  Margin="0,0,6,0"
                />
                <TextBlock
                  x:Name="TxtHotkeyHorizontal"
                  Text="CTRL+ALT+P"
                  FontSize="14"
                  FontWeight="SemiBold"
                  Foreground="#B266FF"
                  VerticalAlignment="Center"
                />
              </StackPanel>-->
            </StackPanel>
          </StackPanel>
        </Grid>
      </Grid>
    </Grid>
  </Grid>
</Window>
